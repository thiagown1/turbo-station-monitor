{
  "name": "turbo-station-monitor",
  "version": "1.0.15",
  "description": "Observability stack for Turbo Station — OCPP collector, mobile telemetry, Vercel drain, GitHub CI webhook, alert engine, and Pagarme status webhook",
  "private": true,
  "scripts": {
    "start": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop ecosystem.config.js",
    "restart": "pm2 restart ecosystem.config.js",
    "status": "pm2 list",
    "logs": "pm2 logs",
    "test": "node test/test-causal-correlation.js && node test/test-charger-fault-backoff.js && node test/test-cable-theft-alert.js && node test/test-night-watch-escalation.js",
    "test:telemetry": "node test/test-telemetry-endpoint.js",
    "test:telemetry:live": "node test/test-telemetry-endpoint.js --live",
    "test:alerts": "node test/test-alert-engine.js",
    "test:causal": "node test/test-causal-correlation.js",
    "test:backoff": "node test/test-charger-fault-backoff.js",
    "check:requires": "node scripts/ci/check-requires.js",
    "db:create": "node scripts/create-db.js",
    "db:backup": "node scripts/db-backup.js",
    "maintenance": "node scripts/daily-maintenance.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "express": "^5.2.1",
    "node-fetch": "^2.7.0",
    "sharp": "^0.35.2",
    "ws": "^8.19.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "TurboStation Team",
  "license": "UNLICENSED",
  "devDependencies": {
    "supertest": "^7.2.2"
  }
}
