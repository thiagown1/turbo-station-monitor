# ─── Telemetry API Key ───
TELEMETRY_API_KEY=your-api-key-here

# ─── Ports ───
VERCEL_DRAIN_PORT=3001
GITHUB_WEBHOOK_PORT=3002
MOBILE_TELEMETRY_PORT=3003
PAGARME_WEBHOOK_PORT=3004

# ─── Vercel Drain ───
DRAIN_SECRET=your-vercel-drain-secret

# ─── GitHub Webhook ───
CI_FIX_MAX_ATTEMPTS=10

# ─── Alert Engine ───
ALERT_TELEGRAM_GROUP=telegram:-5102620169

# ─── Pagarme Status Webhook ───
PAGARME_STATUS_TELEGRAM_TARGET=telegram:-5250194812

# ─── Node Environment ───
NODE_ENV=production

# ─── Monitor API Secret (shared with dashboard) ───
MONITOR_API_SECRET=MONITOR_API_SECRET=8e677889c500d1f614d87bea40ef179121eb26f55dc05a905501a9c80e8de2ab
